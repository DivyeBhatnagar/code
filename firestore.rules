rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the resource
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Helper function to validate required fields
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    // Users collection - root level user data
    match /users/{userId} {
      // Allow users to read and write their own data
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && hasRequiredFields(['updated_at']);
      allow update: if isOwner(userId);
      allow delete: if false; // Prevent deletion of user documents
      
      // Hackathon Plans subcollection
      match /hackathon_plans/{planId} {
        // Allow users to read and write their own plans
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) 
          && hasRequiredFields(['session_id', 'hackathon_name', 'full_plan', 'created_at', 'user_id', 'user_email'])
          && request.resource.data.user_id == request.auth.uid
          && request.resource.data.user_email == request.auth.token.email;
        allow update: if isOwner(userId) 
          && request.resource.data.user_id == resource.data.user_id;
        allow delete: if isOwner(userId); // Allow users to delete their own plans
      }
      
      // Generated Projects subcollection
      match /generated_projects/{projectId} {
        // Allow users to read and write their own projects
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && hasRequiredFields(['project_name', 'user_id', 'user_email'])
          && request.resource.data.user_id == request.auth.uid
          && request.resource.data.user_email == request.auth.token.email;
        allow update: if isOwner(userId)
          && request.resource.data.user_id == resource.data.user_id;
        allow delete: if isOwner(userId); // Allow users to delete their own projects
      }
      
      // Activity Logs subcollection
      match /activity_logs/{activityId} {
        // Allow users to create and read their own activity logs
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && hasRequiredFields(['action', 'user_id', 'timestamp'])
          && request.resource.data.user_id == request.auth.uid;
        allow update: if false; // Activity logs should not be updated
        allow delete: if false; // Activity logs should not be deleted
      }
    }
    
    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
